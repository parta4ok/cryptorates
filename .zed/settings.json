	"format_on_save": "on",
	"wrap_guides": [100],
	// "project_panel": {
	// 	"indent_size": 20,
	// },
	// "git": {
	// 	"inline_blame": {
	// 		"enabled": true,
	// 	},
	// },
	"indent_guides": {
		"enabled": true,
		"coloring": "indent_aware",
	},
	"load_direnv": "direct",
	"tab_size": 4,
	"hard_tabs": true,
	"show_whitespaces": "selection",
	"remove_trailing_whitespace_on_save": true,
	"ensure_final_newline_on_save": true,
	"languages": {
		"Go": {
			"format_on_save": "on",
			"formatter": {
				"external": {
					"command": "goimports",
					"arguments": [],
				},
			},
			"code_actions_on_format": {
				"source.organizeImports": true,
			},
		},
	},
	"lsp": {
		"gopls": {
			"initialization_options": {
				"buildFlags": ["-tags=TEST_L1,TEST_L2,TEST_CONCURRENT"],
			},
		},
	},
}
